generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id          String       @id @default(cuid())
  name        String
  createdAt   DateTime     @default(now())
  departments Department[]
  employees   Employee[]
  users       User[]
}

model User {
  id        String  @id @default(cuid())
  name      String
  email     String  @unique
  password  String
  companyId String
  role      Role
  company   Company @relation(fields: [companyId], references: [id])
}

model Department {
  id        String     @id @default(cuid())
  name      String
  companyId String
  company   Company    @relation(fields: [companyId], references: [id])
  employees Employee[]
}

model Employee {
  id           String      @id @default(cuid())
  name         String
  email        String?
  phone        String?
  position     String
  hireDate     DateTime
  status       String
  driveFolder  String?
  companyId    String
  departmentId String?
  documents    Document[]
  company      Company     @relation(fields: [companyId], references: [id])
  department   Department? @relation(fields: [departmentId], references: [id])
  incidents    Incident[]
}

model Incident {
  id          String   @id @default(cuid())
  type        String
  description String
  date        DateTime @default(now())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
}

model Document {
  id         String   @id @default(cuid())
  name       String
  driveUrl   String
  uploadedAt DateTime @default(now())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
}

enum Role {
  ADMIN
  COMPANY_ADMIN
  USER
}
